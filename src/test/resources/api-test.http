# ============================================================
# CLEANUP - DELETE OPERATIONS (run manually at the very end)
# ============================================================

### [EMPLOYEE] Step 19 - Delete Property
# DELETE {{baseUrl}}/employee/property/delete/{{propertyId}}
# Authorization: Bearer {{employeeToken}}

### [EMPLOYEE] Step 19.1 - Delete Declaration
# DELETE {{baseUrl}}/employee/ipr-declaration/delete/{{declarationId}}
# Authorization: Bearer {{employeeToken}}

### [EMPLOYEE] Step 19.2 - Delete IPR Return (only DRAFT status)
# DELETE {{baseUrl}}/employee/ipr-return/delete/{{iprReturnId}}
# Authorization: Bearer {{employeeToken}}

### [HOD] Step 19.3 - Delete Notification
# DELETE {{baseUrl}}/hod/notification/delete/{{notificationId}}
# Authorization: Bearer {{hodToken}}

### [AUTHORITY] Step 19.4 - Delete User credentials
# DELETE {{baseUrl}}/authority/user/delete/{{employeeId}}
# Authorization: Bearer {{authorityToken}}

### [AUTHORITY] Step 19.5 - Delete Employee
# DELETE {{baseUrl}}/authority/employee/delete/{{employeeId}}
# Authorization: Bearer {{authorityToken}}

### [AUTHORITY] Step 19.6 - Delete Office
# DELETE {{baseUrl}}/authority/office/delete/{{officeId}}
# Authorization: Bearer {{authorityToken}}

### [AUTHORITY] Step 19.7 - Delete Department
# DELETE {{baseUrl}}/authority/department/delete/{{departmentId}}
# Authorization: Bearer {{authorityToken}}


# ============================================================
# COMPLETE END-TO-END WORKFLOW REFERENCE
# ============================================================
# Step 1:  [PUBLIC]     Seed authority user in DB → login → get @authorityToken
# Step 2:  [AUTHORITY]  Create Department
# Step 3:  [AUTHORITY]  Create Office under Department
# Step 4:  [AUTHORITY]  Create Employee (regular)
# Step 5:  [AUTHORITY]  Create Employee (will be HOD)
# Step 6:  [AUTHORITY]  Create HOD credentials (ROLE_HOD)
# Step 7:  [AUTHORITY]  Create Employee credentials (ROLE_EMPLOYEE)
# Step 8:  [PUBLIC]     HOD login → get @hodToken
# Step 9:  [HOD]        Open Filing Window (create notification)
# Step 10: [PUBLIC]     Employee login → get @employeeToken
# Step 11: [EMPLOYEE]   Check filing window is open
# Step 12: [EMPLOYEE]   Create IPR Return (→ DRAFT)
# Step 13: [EMPLOYEE]   Add Property 1 (self-owned)
# Step 14: [EMPLOYEE]   Add Property 2 (spouse)
# Step 15: [EMPLOYEE]   Add Declaration
# Step 16: [EMPLOYEE]   Submit IPR Return (→ SUBMITTED)
# Step 17: [HOD]        View pending returns
# Step 18: [HOD]        Return IPR with remarks (→ RETURNED)
# Step 19: [EMPLOYEE]   Update return / properties
# Step 20: [EMPLOYEE]   Resubmit (→ SUBMITTED again)
# Step 21: [HOD]        Approve IPR Return (→ APPROVED)
# Step 22: [EMPLOYEE]   View workflow log (CREATED→SUBMITTED→RETURNED→SUBMITTED→APPROVED)
# ============================================================
