###
# ============================================================
# IPR MANAGEMENT SYSTEM - TONED DOWN API TEST FILE
# Spring Boot · Java 21 · PostgreSQL · Port 8081
# ============================================================
# INSTRUCTIONS:
# 1. Start your database and backend (auto-updates schema).
# 2. Since Authority is removed, seed the Department, Office, 
#    Employees, and Users directly in the database (SQL below).
# 3. Use Step 1 to log in as HOD      → update @hodToken
# 4. Use Step 2 to log in as Employee → update @employeeToken
# 5. Run steps top-to-bottom to test the flow
# ============================================================
# DATABASE SEED SQL (Run this in PgAdmin/PostgreSQL):
#
# -- Seed Department
# INSERT INTO department (id, name) VALUES (nextval('department_sequence'), 'Finance Department');
#
# -- Seed Office
# INSERT INTO office (id, name, department_id) VALUES (nextval('office_sequence'), 'Accounts Agartala', 1);
#
# -- Seed HOD Employee
# INSERT INTO employee (id, name, email, service, length_of_service, present_post_held, place_of_posting, office_id) 
# VALUES (nextval('employee_sequence'), 'Priyanka Majumdar', 'priyanka@nic.in', 'Tripura Civil Service', '15 years', 'Deputy Director Finance', 'Agartala', 1);
#
# -- Seed Regular Employee
# INSERT INTO employee (id, name, email, service, length_of_service, present_post_held, place_of_posting, office_id) 
# VALUES (nextval('employee_sequence'), 'Rajan Kumar Das', 'rajan@nic.in', 'Tripura Civil Service', '8 years', 'Assistant Accounts Officer', 'Agartala', 1);
#
# -- Seed HOD User Credentials (password: hod@123)
# INSERT INTO users (id, username, password, role, employee_id) 
# VALUES (nextval('user_sequence'), 'hod_finance', 'hod@123', 'ROLE_HOD', 1);
#
# -- Seed Employee User Credentials (password: emp@123)
# INSERT INTO users (id, username, password, role, employee_id) 
# VALUES (nextval('user_sequence'), 'emp_rajan', 'emp@123', 'ROLE_EMPLOYEE', 2);
# ============================================================

@baseUrl        = http://localhost:8081/api/v1
@hodToken       = PASTE_HOD_TOKEN_HERE
@employeeToken  = PASTE_EMPLOYEE_TOKEN_HERE

# ── Common IDs (fill after creation/fetching) ────────────────
@officeId       = 1
@iprReturnId    = 1
@propertyId     = 1
@declarationId  = 1
@notificationId = 1


# ============================================================
# AUTH - LOGIN (public)
# ============================================================

### Step 1 - HOD Login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "username": "hod_finance",
  "password": "hod@123"
}

### → Copy token → paste into @hodToken above


### Step 2 - Employee Login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "username": "emp_rajan",
  "password": "emp@123"
}

### → Copy token → paste into @employeeToken above


# ============================================================
# HOD - FILING WINDOW / NOTIFICATIONS (HOD token required)
# ============================================================

### [HOD] Step 3 - Open Filing Window for the Office
POST {{baseUrl}}/hod/notification/add
Content-Type: application/json
Authorization: Bearer {{hodToken}}

{
  "session": "2025-2026",
  "message": "Annual IPR return filing is now open for 2025-2026. All employees must submit by the deadline.",
  "officeId": {{officeId}},
  "startDate": "2026-07-01",
  "endDate": "2026-08-14",
  "active": true
}

### → Note returned id → set @notificationId


### [HOD] Step 3.1 - Get Active Notification for the Office
GET {{baseUrl}}/hod/notification/get/active/{{officeId}}
Authorization: Bearer {{hodToken}}


### [HOD] Step 3.2 - Extend Filing Window
PUT {{baseUrl}}/hod/notification/update/{{notificationId}}
Content-Type: application/json
Authorization: Bearer {{hodToken}}

{
  "session": "2025-2026",
  "message": "Filing window extended by 2 weeks.",
  "officeId": {{officeId}},
  "startDate": "2026-07-01",
  "endDate": "2026-08-28",
  "active": true
}


# ============================================================
# EMPLOYEE - PROFILE & FILING WORKFLOW
# ============================================================

### [EMPLOYEE] Step 4 - Get My Profile
GET {{baseUrl}}/employee/me
Authorization: Bearer {{employeeToken}}


### [EMPLOYEE] Step 5 - Check if Filing Window is Open
GET {{baseUrl}}/employee/notification/get/active/{{officeId}}
Authorization: Bearer {{employeeToken}}


### [EMPLOYEE] Step 6 - Create IPR Return (DRAFT)
POST {{baseUrl}}/employee/ipr-return/add
Content-Type: application/json
Authorization: Bearer {{employeeToken}}

{
  "reportingYear": "2025-2026",
  "asOnDate": "2026-07-31",
  "totalAnnualIncome": 720000.00,
  "isNoProperty": false
}

### → Note returned iprId → set @iprReturnId


### [EMPLOYEE] Step 7 - Add Property
POST {{baseUrl}}/employee/property/add
Content-Type: application/json
Authorization: Bearer {{employeeToken}}

{
  "iprReturnId": {{iprReturnId}},
  "locationAddress": "Plot No. 12, Krishnanagar, Agartala, Tripura - 799001",
  "propertyType": "Residential House",
  "propertyDescription": "Double storey RCC building",
  "acquisitionCost": 2500000.00,
  "acquisitionYear": "2019",
  "presentValue": 3200000.00,
  "ownerName": "Rajan Kumar Das",
  "ownerRelation": "SELF",
  "acquisitionMode": "Purchase",
  "acquisitionDetails": "Registered at Sub-Registrar office, Agartala.",
  "annualIncome": 0.00,
  "remarks": "Self-occupied"
}

### → Note returned id → set @propertyId


### [EMPLOYEE] Step 8 - Add Declaration
POST {{baseUrl}}/employee/declaration/add
Content-Type: application/json
Authorization: Bearer {{employeeToken}}

{
  "iprReturnId": {{iprReturnId}},
  "declarationText": "I hereby declare that the return enclosed are complete, true and correct to the best of my knowledge.",
  "agreed": true,
  "declarationDate": "2026-07-31",
  "place": "Agartala",
  "employeeSignature": "Rajan Kumar Das"
}


### [EMPLOYEE] Step 9 - Submit IPR Return (DRAFT → SUBMITTED)
PUT {{baseUrl}}/employee/ipr-return/submit/{{iprReturnId}}
Authorization: Bearer {{employeeToken}}


# ============================================================
# HOD - REVIEW & APPROVE/RETURN WORKFLOW
# ============================================================

### [HOD] Step 10 - View Pending returns in department
GET {{baseUrl}}/hod/ipr-return/pending
Authorization: Bearer {{hodToken}}


### [HOD] Step 11 - Get IPR Return by ID
GET {{baseUrl}}/hod/ipr-return/get/{{iprReturnId}}
Authorization: Bearer {{hodToken}}


### [HOD] Step 12 - Return IPR to Employee (for correction)
PUT {{baseUrl}}/hod/ipr-return/return/{{iprReturnId}}
Content-Type: application/json
Authorization: Bearer {{hodToken}}

{
  "remarks": "Please provide more details on property acquisition cost."
}

# Employee then fixes details and calls Submit again (Step 9) before proceeding.


### [HOD] Step 13 - Approve Employee's IPR Return (Final terminal state for Employees)
PUT {{baseUrl}}/hod/ipr-return/approve/{{iprReturnId}}
Content-Type: application/json
Authorization: Bearer {{hodToken}}

{
  "remarks": "Reviewed and Approved."
}


### [HOD] Step 14 - View Workflow log of return
GET {{baseUrl}}/hod/workflow-log/get/{{iprReturnId}}
Authorization: Bearer {{hodToken}}


# ============================================================
# HOD - FILING THEIR OWN RETURN
# ============================================================

### [HOD] Step 15 - HOD creates their own return
POST {{baseUrl}}/employee/ipr-return/add
Content-Type: application/json
Authorization: Bearer {{hodToken}}

{
  "reportingYear": "2025-2026",
  "asOnDate": "2026-07-31",
  "totalAnnualIncome": 1200000.00,
  "isNoProperty": true
}

### → Set new @iprReturnId


### [HOD] Step 16 - HOD submits their own return (Automatically marked FORWARDED)
PUT {{baseUrl}}/employee/ipr-return/submit/{{iprReturnId}}
Authorization: Bearer {{hodToken}}


# ============================================================
# ERROR & SECURITY TESTING (Validating Bug Fixes)
# ============================================================

### [TEST] Step 17 - Login with wrong credentials → 400 Bad Request
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "username": "emp_rajan",
  "password": "wrongpassword"
}


### [TEST] Step 18 - Access HOD endpoint with Employee token → 403 Forbidden
GET {{baseUrl}}/hod/ipr-return/pending
Authorization: Bearer {{employeeToken}}


### [TEST] Step 19 - Request with invalid JWT Token → 401 Unauthorized (returns clean JSON error body)
GET {{baseUrl}}/employee/me
Authorization: Bearer invalid.token.string


### [TEST] Step 20 - Validation failure (blank year) → 400 Bad Request (returns structured fieldErrors mapping)
POST {{baseUrl}}/employee/ipr-return/add
Content-Type: application/json
Authorization: Bearer {{employeeToken}}

{
  "reportingYear": "",
  "asOnDate": "2026-07-31",
  "totalAnnualIncome": 720000.00,
  "isNoProperty": false
}
